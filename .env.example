BYBIT_DEMO_API_URL=https://api-demo.bybit.com
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=
BYBIT_DEMO_ACCEPTANCE_ENABLED=false
BYBIT_DEMO_ACCEPTANCE_SYMBOL=
BYBIT_REQUEST_TIMEOUT_MS=10000
RECONCILIATION_INTERVAL_MS=15000
LIFECYCLE_INTERVAL_MS=10000
WORKER_RETRY_ATTEMPTS=3
WORKER_BACKOFF_BASE_MS=500
WORKER_BACKOFF_MAX_MS=5000
WORKER_SHUTDOWN_GRACE_MS=10000
SCANNER_CONCURRENCY=4
SCANNER_DEPTH_SHORTLIST=80
PAPER_STARTING_BALANCE=10000
EXECUTION_FEE_RATE=0.0006
EXECUTION_SLIPPAGE_RATE=0.0002

# Phase 7 risk protection defaults (positive values only)
MAX_RISK_PER_TRADE_PCT=1
MAX_AGGREGATE_OPEN_RISK_PCT=5
MAX_DAILY_REALIZED_LOSS=300
MAX_DAILY_REALIZED_PROFIT=500
MAX_CONSECUTIVE_LOSSES=3
BALANCE_STALE_MS=60000

# Structured log retention (journal is never pruned)
LOG_MAX_RECORDS=2000
